# Admin
# Clave del panel admin
VITE_ADMIN_PASSWORD=cambia-esta-clave

# EmailJS
# Crear cuenta en https://emailjs.com
# 1. Conectar un servicio de email
# 2. Crear un template con variables: {{nombre}}, {{email}}, {{mensaje}}
# 3. Copiar los IDs aqui
VITE_EMAILJS_SERVICE_ID=service_xxxxxxx
VITE_EMAILJS_TEMPLATE_ID=template_xxxxxxx
VITE_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxx
